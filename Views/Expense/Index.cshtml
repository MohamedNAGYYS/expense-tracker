@model List<Expense> // Get All expenses

@*Dispaly the title*@

<form method="get" asp-action="Index">
    <label>Filter by Category</label>
    
    <select name="category" class="form-select" style="width:200px; display:inline-block;">
        <option value="All">All</option>
        @foreach(var cat in ViewBag.Categories){
            <option value="@cat">@cat</option>

        }
    
        
        @* <option value="Food">Food</option>
        <option value="Entertainment">Entertainment</option>
        <option value="Bills">Bills</option>
        <option value="Transport">Transport</option> *@

    </select>

    <button type="submit" class="btn btn-primary" style="border-radius:10px;">Filter</button>


    
    <input type="text" placeholder="Search.." name="search" style="border-radius: 5px;"/>
    <button type="submit" class="btn btn-outline-primary" style="border-radius: 10px;">Search</button>
    
</form>
<br />

<h1>Expenses</h1>


<a asp-action="Create" class="btn btn-outline-secondary" style="border-radius: 10px;">Create New Expense</a>



<br />
<br />


@*Check if it exists and not null*@
@if(Model != null && Model.Any())
{

    @*Then for through on the model and display *@

    <a asp-action="Index" asp-route-sort="amount">Amount</a>
    <table class="table table-striped table-bordered">

        <thead>
            <tr>
                <th>Description</th>
                <th>Amount</th>
                <th>Category</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>


        <tbody>

            @foreach(var expense in Model)
            {
                    <tr>
                        <td>@expense.Description</td>
                        <td>@expense.Amount.ToString("C")</td> @*$15.00*@
                        <td>@expense.Category</td>
                        <td>@expense.Date.ToShortDateString()</td> @*8/3/2026*@
                        <td>
                            <a asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-outline-primary" style="border-radius: 10px;">Edit</a>
                            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@expense.Id" style="border-radius: 10px;">Delete</a>
                        </td>
                        
            
            

                    </tr>

            }
        </tbody>

        <tfoot>
            <tr>
                <td><strong>Total</strong></td>
                <td><strong>@Model.Sum(e=>e.Amount).ToString("C")</strong></td>
                <td></td>
                <td></td>
                <td></td>
            </tr>
        </tfoot>
    </table>
}

else
{
    <p>No Expenses Found!</p>
}