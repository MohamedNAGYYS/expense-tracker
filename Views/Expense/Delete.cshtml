@model Expense


<br />
<br />
<h2 class="text-center">Delete Expense</h2>

<p class="text-center">Are you sure you want to delete this expense?</p>


<div class="text-center">

    <p><strong>Description:</strong>@Model.Description</p>
    <p><strong>Amount:</strong>@Model.Amount</p>
    <p><strong>Category:</strong>@Model.Category</p>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id"/> @*It sends the expense id back to controller*@
        <button type="submit" class="btn btn-outline-danger" style="border-radius: 10px;">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 10px;">Cancel</a>
    </form>
</div>